worker_processes auto;
error_log /dev/stderr notice;

events {
    worker_connections 1024;
}

rtmp {
    server {
        access_log /dev/stdout;
        listen 1935;
        chunk_size 4096;

        include /etc/nginx/publish-allowlist.conf;
        deny play all;

        application __RTMP_APP__ {
            live on;
            record all;
            record_path __RECORD_PATH__;
            record_unique on;
            record_suffix __RECORD_SUFFIX__;
        }
    }
}
