# Порты
RTMP_PORT=1935

# Путь для хранения записей
HOST_RECORD_PATH=./recordings

# Имя RTMP application в URL: rtmp://host:1935/<RTMP_APP>/<stream-key>
RTMP_APP=live

# Путь внутри контейнера. Для TrueNAS обычно менять не нужно.
RECORD_PATH=/recordings

# Суффикс имени записанного файла
RECORD_SUFFIX=_%Y-%m-%d_%H-%M-%S.flv

# Разрешённые IP/CIDR для publish. Можно перечислять через запятую.
# Пустое значение = publish разрешён с любого IP.
PUBLISH_ALLOWLIST=192.168.0.101,192.168.0.102,10.0.0.0/24
